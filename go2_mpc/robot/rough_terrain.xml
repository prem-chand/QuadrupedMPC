<mujoco model="go2 rough terrain">
  <include file="go2.xml"/>

  <statistic center="0 0 0.1" extent="2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="obstacle" rgba="0.6 0.4 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    
    <!-- Base floor -->
    <geom name="floor" pos="0 0 -0.05" size="10 10 0.05" type="box" material="groundplane"/>
    
    <!-- Rough terrain bumps (0.02m height variation) -->
    <geom name="bump1" pos="1.0 0.0 0.02" size="0.3 0.3 0.02" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    <geom name="bump2" pos="1.5 0.3 0.025" size="0.25 0.25 0.025" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    <geom name="bump3" pos="2.0 -0.2 0.015" size="0.2 0.2 0.015" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    <geom name="bump4" pos="2.5 0.1 0.03" size="0.35 0.35 0.03" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    <geom name="bump5" pos="3.0 0.4 0.02" size="0.28 0.28 0.02" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    
    <!-- Gentle slope (10 degrees) -->
    <geom name="slope" pos="3.5 0.0 0.1" size="1.0 0.8 0.01" type="box" material="obstacle" 
          euler="0 5 0" condim="3" friction="0.6 0.02 0.01"/>
    
    <!-- Small step -->
    <geom name="step" pos="4.5 0.0 0.05" size="0.3 0.6 0.05" type="box" material="obstacle" condim="3" friction="0.6 0.02 0.01"/>
    
    <!-- Second slope (15 degrees) -->
    <geom name="slope2" pos="5.0 0.0 0.15" size="1.0 0.8 0.01" type="box" material="obstacle" 
          euler="0 8 0" condim="3" friction="0.6 0.02 0.01"/>
    
  </worldbody>
</mujoco>
